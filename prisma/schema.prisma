generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GenerationJobStatus {
  draft_ready
  awaiting_payment_or_credit
  queued
  claimed
  provider_submitted
  provider_processing
  copying_to_s3
  quality_check
  partially_ready
  ready
  failed
  needs_support
}

enum GenerationType {
  song
  instrumental
}

enum CreditReservationStatus {
  reserved
  captured
  released
}

enum PaymentProvider {
  stripe
  nowpayments
  fake
}

enum PromoStatus {
  active
  disabled
  expired
}

model User {
  id                 String              @id @default(cuid())
  email              String?             @unique
  displayName        String?
  isAdmin            Boolean             @default(false)
  createdAt          DateTime            @default(now())
  anonymousSessions  AnonymousSession[]
  drafts             SongDraft[]
  creditLedger       CreditLedger[]
  creditReservations CreditReservation[]
  paymentIntents     PaymentIntent[]
  shareLinks         ShareLink[]
  promoRedemptions   PromoRedemption[]
  adminAuditEvents   AdminAuditEvent[]   @relation("AdminAuditActor")
}

model AnonymousSession {
  id              String    @id @default(cuid())
  browserHash     String    @unique
  expiresAt       DateTime
  claimedByUserId String?
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())
  claimedByUser   User?     @relation(fields: [claimedByUserId], references: [id])
}

model CreditLedger {
  id               String        @id @default(cuid())
  userId           String
  delta            Int
  reason           String
  packageId        String?
  paymentIntentId  String?
  generationJobId  String?
  idempotencyKey   String        @unique
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id])
  paymentIntent    PaymentIntent? @relation(fields: [paymentIntentId], references: [id])
}

model CreditReservation {
  id               String                  @id @default(cuid())
  userId           String
  generationJobId  String                  @unique
  creditsReserved  Int
  status           CreditReservationStatus @default(reserved)
  idempotencyKey   String                  @unique
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  user             User                    @relation(fields: [userId], references: [id])
  generationJob    GenerationJob           @relation(fields: [generationJobId], references: [id])
}

model SongDraft {
  id            String         @id @default(cuid())
  userId        String?
  title         String
  lyrics        String
  style         String
  voiceGender   String?
  status        String         @default("draft")
  messageCount  Int            @default(0)
  promptVersion String         @default("web-v1")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User?          @relation(fields: [userId], references: [id])
  messages      DraftMessage[]
  jobs          GenerationJob[]
}

model DraftMessage {
  id                 String    @id @default(cuid())
  draftId            String
  role               String
  content            String
  structuredSongJson Json?
  createdAt          DateTime  @default(now())
  draft              SongDraft @relation(fields: [draftId], references: [id])
}

model GenerationJob {
  id                String                @id @default(cuid())
  draftId           String
  userId            String
  provider          String?
  providerTaskId    String?
  status            GenerationJobStatus   @default(queued)
  type              GenerationType        @default(song)
  creditCost        Int                   @default(1)
  errorCode         String?
  errorMessage      String?
  lockedAt          DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  draft             SongDraft             @relation(fields: [draftId], references: [id])
  reservation       CreditReservation?
  attempts          GenerationAttempt[]
  tracks            Track[]
}

model GenerationAttempt {
  id                   String        @id @default(cuid())
  generationJobId       String
  provider             String
  requestHash          String
  providerTaskId       String?
  status               String
  providerCostConsumed Boolean       @default(false)
  fallbackEligible     Boolean       @default(true)
  terminalReason       String?
  rawRequestJson       Json?
  rawCallbackJson      Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  generationJob        GenerationJob @relation(fields: [generationJobId], references: [id])

  @@index([provider, providerTaskId])
}

model Track {
  id                    String        @id @default(cuid())
  generationJobId        String
  variantIndex           Int
  title                 String
  storageKey            String
  durationSec           Int?
  mimeType              String
  sizeBytes             Int
  providerSourceUrlHash String?
  createdAt             DateTime      @default(now())
  generationJob          GenerationJob @relation(fields: [generationJobId], references: [id])

  @@unique([generationJobId, variantIndex])
}

model PaymentIntent {
  id                 String          @id @default(cuid())
  userId             String
  provider           PaymentProvider
  providerPaymentId  String?
  providerCheckoutId String?
  packageCode        String
  amount             Int
  currency           String
  status             String
  metadata           Json?
  idempotencyKey     String          @unique
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user               User            @relation(fields: [userId], references: [id])
  events             PaymentEvent[]
  creditLedger       CreditLedger[]
}

model PaymentEvent {
  id                String        @id @default(cuid())
  paymentIntentId   String
  provider          PaymentProvider
  providerEventId   String
  signatureHash     String?
  eventType         String
  payloadJson       Json
  processedAt       DateTime?
  createdAt         DateTime      @default(now())
  paymentIntent     PaymentIntent @relation(fields: [paymentIntentId], references: [id])

  @@unique([provider, providerEventId])
}

model PromoCampaign {
  id               String      @id @default(cuid())
  createdByAdminId String
  name             String
  description      String?
  status           PromoStatus @default(active)
  startsAt         DateTime?
  expiresAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  codes            PromoCode[]
}

model PromoCode {
  id                 String            @id @default(cuid())
  campaignId         String
  codeHash           String            @unique
  displayPrefix      String
  credits            Int
  maxRedemptions     Int
  perUserLimit       Int               @default(1)
  allowedEmailDomain String?
  allowedEmailHash   String?
  status             PromoStatus       @default(active)
  expiresAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  campaign           PromoCampaign     @relation(fields: [campaignId], references: [id])
  redemptions        PromoRedemption[]
}

model PromoRedemption {
  id               String       @id @default(cuid())
  promoCodeId      String
  userId           String
  creditLedgerId   String
  idempotencyKey   String       @unique
  redeemedAt       DateTime     @default(now())
  metadataJson     Json?
  promoCode        PromoCode    @relation(fields: [promoCodeId], references: [id])
  user             User         @relation(fields: [userId], references: [id])
}

model ShareLink {
  id           String    @id @default(cuid())
  userId       String
  trackGroupId String
  tokenHash    String    @unique
  status       String    @default("active")
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])
}

model ProviderEvent {
  id          String   @id @default(cuid())
  provider    String
  jobId       String?
  eventType   String
  payloadJson Json
  createdAt   DateTime @default(now())
}

model ErrorEvent {
  id          String   @id @default(cuid())
  severity    String
  area        String
  userId      String?
  jobId       String?
  message     String
  stackHash   String?
  payloadJson Json?
  createdAt   DateTime @default(now())
}

model AdminAuditEvent {
  id            String   @id @default(cuid())
  adminUserId   String
  action        String
  targetType    String
  targetId      String?
  reason        String
  payloadJson   Json?
  createdAt     DateTime @default(now())
  adminUser     User     @relation("AdminAuditActor", fields: [adminUserId], references: [id])
}
